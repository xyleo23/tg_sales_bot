# Триал для новых пользователей
TRIAL_DAYS=7

# Задержки рассылки (секунды)
MAILING_DELAY_MIN=30
MAILING_DELAY_MAX=90
MAILING_MAX_PER_ACCOUNT=20

# Задержка инвайтинга (секунды)
INVITE_DELAY_SEC=3
