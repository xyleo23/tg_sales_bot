ADMIN_IDS=
TESTER_IDS=

# Telegram MTProto API (https://my.telegram.org)
TG_API_ID=12345
TG_API_HASH=your_api_hash

# БД: по умолчанию SQLite, для production — PostgreSQL
# DATABASE_URL=postgresql+asyncpg://user:pass@localhost:5432/tg_sales_bot

# Оплата (опционально): Telegram Payments через @BotFather
PAYMENT_PROVIDER_TOKEN=
